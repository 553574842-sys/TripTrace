# Copy this file to .env before running Docker Compose.
TRIPTRACE_IMAGE=triptrace:local
TRIPTRACE_CONTAINER_NAME=triptrace
TRIPTRACE_PORT=3000
TRIPTRACE_DATA_DIR=./data
TRIPTRACE_UPLOAD_DIR=./uploads
TZ=Asia/Shanghai
DEFAULT_LANGUAGE=zh
LOG_LEVEL=info

# Local drill defaults. Replace with the public HTTPS URL for production.
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
FORCE_HTTPS=false
TRUST_PROXY=0

# Generate a unique 64-character hex value before production deployment.
ENCRYPTION_KEY=

# Used only on the first boot of a new data directory.
ADMIN_EMAIL=admin@triptrace.local
ADMIN_PASSWORD=

# Domestic map and AI integrations. Never commit real keys.
AMAP_API_KEY=
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Optional: your own GitHub repository in owner/repository format.
# When unset, release history and automatic version checks stay disabled.
PROJECT_REPOSITORY=
